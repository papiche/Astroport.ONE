##############################################################################
## ─── Swarm SSH Gateway (fallback quand IPFS P2P non disponible) ──────────
## Passerelle utilisée par ollama.me.sh, comfyui.me.sh, perplexica.me.sh, etc.
## pour le tunnel SSH de secours (si aucun nœud P2P accessible).
## Laisser vide pour désactiver le fallback SSH.
SWARM_REMOTE_HOST="scorpio.copylaradio.com"
SWARM_REMOTE_USER="frd"
SWARM_REMOTE_PORT_IPV4=2122   # Port NAT IPv4 (ex: 2122 derrière un routeur)
SWARM_REMOTE_PORT_IPV6=22     # Port SSH direct IPv6

## ─── Services DRAGON P2P privés ──────────────────────────────────────────
## Slugs séparés par espaces à NE PAS publier via DRAGON P2P dans le swarm.
## L'admin garde ces services inaccessibles aux autres stations.
## Slugs disponibles : ollama open-webui paperclip qdrant comfyui orpheus
##                     perplexica nextcloud-app nextcloud-aio npm webtop-http
##                     webtop-https ssh
## Exemple : DRAGON_PRIVATE_SERVICES="qdrant nextcloud-app"
DRAGON_PRIVATE_SERVICES=""
