myLIBRA="https://ipfs.copylaradio.com" # For "localhost user" prefered IPFS gateway
myASTROPORT=http://127.0.0.1:12345 # https://astroport.mydomain.tld # :12345: Swarm discovery
myIPFS=http://127.0.0.1:8080 # https://ipfs.mydomain.tld # :8080: Your IPFS Gateway
myRELAY=ws://127.0.0.1:7777 # wss://relay.mydomain.tld # :7777 : Your strfry NOSTR relay
uSPOT=http://127.0.0.1:54321 # https://u.mydomain.tld # :54321 : Your API uSPOT
myCORACLE="${myIPFS}/ipns/coracle.copylaradio.com" # Coracle Nostr client via IPFS

###################################
## COPYLARADIO UPLANET ZEN ECONOMY
## ./RUNTIME/ZEN.ECONOMY.sh 
#################################### 
######## VALEUR ZEN DU NODE ########
MACHINE_VALUE_ZEN=500 
################################################ 
# ARMATEUR + CAPTAIN decision (9, 14, 35?)
# Reflects House + Energy + Network for Astroport preservation
PAF=0
# MULTIPASS 10 GB
NCARD=1
# ZENCARD 128 GB
ZCARD=4

######################################## 
# Niveau de détail des logs
LOG_LEVEL=INFO   # DEBUG, INFO, WARNING, ERROR

######################################## 
# Desktop mode espeak
ENABLE_AUDIO_NOTIFICATIONS=yes

